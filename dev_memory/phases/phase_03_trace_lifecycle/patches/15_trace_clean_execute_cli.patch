+
+
+def _fsync_parent_dir(path: Path) -> None:
+    flags = getattr(os, "O_DIRECTORY", None)
+    if flags is None:
+        return
+    dir_fd = os.open(path, os.O_RDONLY | flags)
+    try:
+        os.fsync(dir_fd)
+    finally:
+        os.close(dir_fd)
