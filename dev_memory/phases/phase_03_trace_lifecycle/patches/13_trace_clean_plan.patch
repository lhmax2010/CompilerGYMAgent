+def _bytes_without_ranges(raw: bytes, ranges: tuple[ByteRange, ...]) -> bytes:
+    chunks: list[bytes] = []
+    cursor = 0
+    for item in ranges:
+        chunks.append(raw[cursor : item.start])
+        cursor = item.end
+    chunks.append(raw[cursor:])
+    return b"".join(chunks)
